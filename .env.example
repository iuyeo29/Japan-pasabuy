# Prisma (Supabase Postgres) — from Supabase dashboard: Connect -> ORM -> Prisma
DATABASE_URL="postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Supabase Storage — from Supabase dashboard: Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[service-role-key — keep this secret, never expose client-side]"

# Clerk — from clerk.com dashboard: your application's API Keys page
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
